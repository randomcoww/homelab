{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "maxMajorIncrement": 0,
  "lockFileMaintenance": {
    "enabled": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^config_env\\.tf$/"
      ],
      "matchStrings": [
        "(?<depName>(?<repository>[a-z0-9.-]+(?::\\d+|)(?:/[a-z0-9-]+|)+)/(?<image>[a-z0-9.-]+)):(?<tag>(?<currentValue>(?<version>[\\w.]+)(?:-(?<compat>[\\w.-]+))?)(?:@(?<currentDigest>sha256:[a-f0-9]+))?)"
      ],
      "autoReplaceStringTemplate": "{{{depName}}}:{{{newValue}}}@{{{newDigest}}}",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.tf$/"
      ],
      "matchStrings": [
        "\"(?<currentValue>[^\"]+)\" # renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: registryUrl=(?<registryUrl>[^\\s]+?))?(?: depType=(?<depType>[^\\s]+?))?\\s"
      ],
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "!randomcoww/fedora-coreos-config-custom",
        "!docker.io/pgsty/minio"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "ignoreTests": true,
      "groupName": "renovate"
    },
    {
      "matchPackageNames": [
        "reg.cluster.internal/randomcoww/qrcode-resource",
        "docker.io/cloudflare/cloudflared"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "ignoreTests": true,
      "groupName": "renovate"
    },
    {
      "matchDatasources": [
        "terraform-provider",
        "terraform-module"
      ],
      "registryUrls": [
        "https://registry.opentofu.org"
      ]
    },
    {
      "matchPackageNames": [
        "docker.io/pgsty/minio"
      ],
      "versioning": "regex:^RELEASE\\.(?<major>\\d{4})-(?<minor>\\d{2})-(?<patch>\\d{2})T(?<build>\\d{2}-\\d{2}-\\d{2})Z$"
    },
    {
      "matchPackageNames": [
        "reg.cluster.internal/randomcoww/llama-swap-ffmpeg"
      ],
      "versioning": "regex:^unified-vulkan-(?<major>\\d{4})-(?<minor>\\d{2})-(?<patch>\\d{2}).(?<build>\\d+)$"
    },
    {
      "matchPackageNames": [
        "reg.cluster.internal/randomcoww/juicefs"
      ],
      "versioning": "regex:^ce-v(?<major>\\d+).(?<minor>\\d+).(?<patch>\\d+).(?<build>\\d+)$"
    },
    {
      "matchDepTypes": [
        "helm_release",
        "helm_regex"
      ],
      "pinDigests": false
    }
  ]
}