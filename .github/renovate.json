{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^config_env.tf$/"
      ],
      "matchStrings": [
        "(?<depName>(?<repository>[a-z0-9.-]+(?::\\d+|)(?:/[a-z0-9-]+|)+)/(?<image>[a-z0-9.-]+)):(?<tag>(?<currentValue>(?<version>[\\w.]+)(?:-(?<compat>[\\w.-]+))?)(?:@(?<currentDigest>sha256:[a-f0-9]+))?)"
      ],
      "autoReplaceStringTemplate": "{{{depName}}}:{{{newValue}}}@{{{newDigest}}}",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^config_env.tf$/"
      ],
      "matchStrings": [
        "\"(?<currentValue>[^\"]+)\" # renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)\\s"
      ],
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "reg.cluster.internal/randomcoww/qrcode-resource"
      ],
      "versioning": "regex:^(((?<compatibility>[\\w-]+)-)?[bv])?(?<minor>\\d+)(\\.(?<patch>\\d+)(\\.(?<build>\\d+))?)?(-(?<compat>[\\w.-]+))?$"
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "ignoreTests": true,
      "groupName": "renovate"
    },
    {
      "matchDepTypes": ["helm_release"],
      "pinDigests": false
    },
    {
      "matchDatasources": [
        "terraform-provider",
        "terraform-module"
      ],
      "registryUrls": [
        "https://registry.opentofu.org"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": false
    }
  ]
}